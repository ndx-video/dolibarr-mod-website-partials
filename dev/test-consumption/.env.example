# Dolibarr module-dev base (no trailing slash).
# Prefer http:// for local Node SSR — Caddy tls internal is not in the system trust store.
PARTIALS_BASE_URL=http://partials.gandalf.lan

# Dolibarr user API key (Users → admin → API key)
DOLAPIKEY=

# Dedicated website ref for destructive CRUD harness runs
WEBSITE_REF=demo-partials

# Website ref used by the island demo page (public .json/.html)
PUBLIC_WEBSITE_REF=main-website

# Island slug for the demo page
PUBLIC_SLUG=welcome
